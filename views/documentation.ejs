    </table>

    <h2 id="frontend-integration">📱 Frontend Integration</h2>
    
    <h3>React Native / Expo Example</h3>
    <div class="code-block">
      <code><span class="comment">// Login Example</span><br>
<span class="param">const</span> login = <span class="keyword">async</span> (phone, password) => {<br>
&nbsp;&nbsp;<span class="param">const</span> response = <span class="keyword">await</span> fetch(<span class="string">'http://localhost:5000/api/login'</span>, {<br>
&nbsp;&nbsp;&nbsp;&nbsp;method: <span class="string">'POST'</span>,<br>
&nbsp;&nbsp;&nbsp;&nbsp;headers: {<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="string">'Content-Type'</span>: <span class="string">'application/json'</span>,<br>
&nbsp;&nbsp;&nbsp;&nbsp;},<br>
&nbsp;&nbsp;&nbsp;&nbsp;body: JSON.stringify({ phone, password }),<br>
&nbsp;&nbsp;});<br>
&nbsp;&nbsp;<span class="param">const</span> data = <span class="keyword">await</span> response.json();<br>
&nbsp;&nbsp;<span class="keyword">if</span> (data.token) {<br>
&nbsp;&nbsp;&nbsp;&nbsp;<span class="comment">// Store token securely</span><br>
&nbsp;&nbsp;&nbsp;&nbsp;AsyncStorage.setItem(<span class="string">'token'</span>, data.token);<br>
&nbsp;&nbsp;}<br>
&nbsp;&nbsp;<span class="keyword">return</span> data;<br>
};<br><br>
<span class="comment">// Protected API Call</span><br>
<span class="param">const</span> getDashboard = <span class="keyword">async</span> () => {<br>
&nbsp;&nbsp;<span class="param">const</span> token = <span class="keyword">await</span> AsyncStorage.getItem(<span class="string">'token'</span>);<br>
&nbsp;&nbsp;<span class="param">const</span> response = <span class="keyword">await</span> fetch(<span class="string">'http://localhost:5000/api/admin/dashboard'</span>, {<br>
&nbsp;&nbsp;&nbsp;&nbsp;headers: {<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="string">'Authorization'</span>: <span class="string">`Bearer ${token}`</span>,<br>
&nbsp;&nbsp;&nbsp;&nbsp;},<br>
&nbsp;&nbsp;});<br>
&nbsp;&nbsp;<span class="keyword">return</span> response.json();<br>
};</code>
    </div>

