<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Subscription Plans - PatrolLink</title>
  <link rel="icon" href="/images/logo.png" type="image/x-icon">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: #e2e8f0;
      line-height: 1.6;
      min-height: 100vh;
      padding: 60px 20px;
    }
    .container { max-width: 900px; margin: 0 auto; }
    header {
      text-align: center;
      margin-bottom: 60px;
    }
    h1 {
      font-size: 2.5rem;
      color: #fff;
      margin-bottom: 15px;
    }
    .subtitle {
      color: #94a3b8;
      font-size: 1.1rem;
      max-width: 600px;
      margin: 0 auto;
    }
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 30px;
      margin-bottom: 50px;
    }
    .pricing-card {
      background: #1e293b;
      border-radius: 20px;
      padding: 40px;
      border: 1px solid #334155;
      position: relative;
      transition: transform 0.3s;
      display: flex;
      flex-direction: column;
    }
    .pricing-card:hover {
      transform: translateY(-10px);
      border-color: #2563eb;
    }
    .pricing-card.popular {
      border-color: #2563eb;
      background: #1e293b;
      box-shadow: 0 10px 40px rgba(37, 99, 235, 0.1);
    }
    .popular-badge {
      position: absolute;
      top: -15px;
      right: 20px;
      background: #2563eb;
      color: #fff;
      padding: 5px 15px;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 700;
    }
    .plan-name {
      font-size: 1.2rem;
      color: #94a3b8;
      font-weight: 600;
      margin-bottom: 10px;
    }
    .price {
      font-size: 3rem;
      color: #fff;
      font-weight: 800;
      margin-bottom: 20px;
    }
    .price span {
      font-size: 1rem;
      color: #94a3b8;
      font-weight: 400;
    }
    .features-list {
      list-style: none;
      margin-bottom: 30px;
      flex-grow: 1;
    }
    .features-list li {
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      color: #cbd5e1;
    }
    .features-list li::before {
      content: '✓';
      color: #22c55e;
      margin-right: 10px;
      font-weight: bold;
    }
    .btn {
      display: block;
      text-align: center;
      background: #2563eb;
      color: #fff;
      padding: 16px;
      border-radius: 12px;
      text-decoration: none;
      font-weight: 700;
      transition: background 0.2s;
    }
    .btn:hover {
      background: #1d4ed8;
    }
    .btn-outline {
      background: transparent;
      border: 2px solid #334155;
    }
    .btn-outline:hover {
      border-color: #60a5fa;
      background: rgba(96, 165, 250, 0.05);
    }
    .footer-note {
      text-align: center;
      color: #64748b;
      font-size: 0.9rem;
    }
    .back-link {
      display: block;
      text-align: center;
      margin-top: 30px;
      color: #94a3b8;
      text-decoration: none;
    }
    .back-link:hover { color: #fff; }
    .skip-container {
      text-align: right;
      margin-bottom: 20px;
    }
    .skip-top-link {
      margin-top: 0;
      display: inline-block;
      font-size: 0.95rem;
      font-weight: 500;
      color: #3b82f6;
    }
    .skip-top-link:hover {
      color: #60a5fa;
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Choose Your Plan</h1>
      <p class="subtitle">Get full access to the PatrolLink API, documentation, and real-time monitoring dashboard.</p>
    </header>

    <div class="skip-container">
      <a href="/api-endpoints" class="skip-top-link continue-link-dynamic">Skip for now &rarr;</a>
    </div>

    <div class="pricing-grid">
      <!-- Monthly Plan -->
      <div class="pricing-card">
        <div class="plan-name">Monthly</div>
        <div class="price">KES 15,000<span>/mo</span></div>
        <ul class="features-list">
          <li>Full API Access</li>
          <li>Unlimited Security Guards</li>
          <li>Real-time Dashboard</li>
          <li>Email Support</li>
        </ul>
        <a href="#" class="btn btn-outline" onclick="selectPlan('monthly')">Choose Monthly</a>
      </div>

      <!-- Quarterly Plan -->
      <div class="pricing-card">
        <div class="plan-name">Quarterly (3 Mo)</div>
        <div class="price">KES 44,500<span>/term</span></div>
        <ul class="features-list">
          <li>Everything in Monthly</li>
          <li>Unlimited Security Guards</li>
          <li>Priority Email Support</li>
          <li>10% Savings</li>
        </ul>
        <a href="#" class="btn btn-outline" onclick="selectPlan('quarterly')">Choose Quarterly</a>
      </div>

      <!-- 6 Months Plan -->
      <div class="pricing-card">
        <div class="plan-name">Bi-Annual (6 Mo)</div>
        <div class="price">KES 89,500<span>/term</span></div>
        <ul class="features-list">
          <li>Everything in Quarterly</li>
          <li>Unlimited Security Guards</li>
          <li>WhatsApp Support</li>
          <li>15% Savings</li>
        </ul>
        <a href="#" class="btn btn-outline" onclick="selectPlan('biannual')">Choose 6 Months</a>
      </div>

      <!-- Yearly Plan -->
      <div class="pricing-card popular">
        <div class="popular-badge">BEST VALUE</div>
        <div class="plan-name">Yearly</div>
        <div class="price">KES 175,500<span>/yr</span></div>
        <ul class="features-list">
          <li>Everything in 6 Months</li>
          <li>Unlimited Security Guards</li>
          <li>Priority 24/7 Support</li>
          <li>Advanced Analytics</li>
          <li>25% Savings</li>
        </ul>
        <a href="#" class="btn" onclick="selectPlan('yearly')">Choose Yearly</a>
      </div>
    </div>

    <div class="footer-note">
      <p>All plans include a 14-day money-back guarantee.</p>
      <a href="/api-endpoints" class="back-link continue-link-dynamic">Continue to API Endpoints (Demo Mode)</a>
    </div>
  </div>

  <script>
    // Handle history recognition for redirection
    const urlParams = new URLSearchParams(window.location.search);
    const returnTo = urlParams.get('returnTo') || '/api-endpoints';
    const dynamicLinks = document.querySelectorAll('.continue-link-dynamic');
    
    dynamicLinks.forEach(link => {
      link.href = returnTo;
      
      // Update text specifically for the footer link if it was the original one
      if (link.classList.contains('back-link')) {
        if (returnTo.includes('documentation')) {
          link.textContent = 'Continue to API Documentation (Demo Mode)';
        } else {
          link.textContent = 'Continue to API Endpoints (Demo Mode)';
        }
      }
    });

    function selectPlan(plan) {
      alert(`You selected the ${plan} plan. Integrating with payment gateway...`);
      // In a real app, this would redirect to a Stripe checkout session
      // For now, let's just redirect to the target page
      window.location.href = returnTo;
    }
  </script>
</body>
</html>
